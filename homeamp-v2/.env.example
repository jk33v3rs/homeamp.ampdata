# HomeAMP V2.0 Environment Configuration
# Copy to .env and customize for your environment

# Database Configuration
DATABASE_URL=mysql+pymysql://webadmin:password@localhost:3369/homeamp
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=False

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=False
API_DEBUG=False

# Security
SECRET_KEY=your-secret-key-change-this-in-production
API_KEY_EXPIRY_DAYS=90

# Agent Configuration
AGENT_ENABLED=True
AGENT_CYCLE_INTERVAL=300
AGENT_HEARTBEAT_INTERVAL=60
AGENT_DISCOVERY_ENABLED=True
AGENT_VARIANCE_ENABLED=True
AGENT_UPDATE_CHECK_ENABLED=True

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/homeamp.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_FORMAT=json

# Backup Configuration
BACKUP_ENABLED=True
BACKUP_DIR=backups/
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_COUNT=10

# MinIO / S3 Storage Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False
MINIO_REGION=us-east-1
MINIO_BUCKET_TILES=pl3xmap-tiles
MINIO_BUCKET_BACKUPS=homeamp-backups

# Tile Watcher (Pl3xMap/LiveAtlas Sync)
TILE_WATCHER_ENABLED=False
TILE_WATCHER_SYNC_INTERVAL=300
TILE_WATCHER_FORCE_SYNC=False

# External Integrations
MODRINTH_API_URL=https://api.modrinth.com/v2
HANGAR_API_URL=https://hangar.papermc.io/api/v1
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=

# Discord Notifications
DISCORD_WEBHOOK_URL=
DISCORD_ENABLED=False

# Redis (Optional Caching)
REDIS_ENABLED=False
REDIS_URL=redis://localhost:6379/0

# Feature Flags
FEATURE_WORLD_MANAGEMENT=False
FEATURE_REGION_TRACKING=False
FEATURE_RANK_MANAGEMENT=False
FEATURE_DATAPACK_MANAGEMENT=True
