FROM ./nomic-embed-text-v2-moe.Q6_K.gguf

TEMPLATE """{{ .Prompt }}"""

PARAMETER stop "<|endoftext|>"
PARAMETER temperature 0
PARAMETER num_ctx 8192

# Nomic Embed Text v2 MoE
# First open-source Mixture of Experts embedding model
# 305M active parameters (475M total)
# BEIR: 52.86, MIRACL: 65.80
# Supports Matryoshka embeddings (768→256 dims)
